# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env
# `.env` is gitignored — never commit real tokens.

# Telegram bot token from @BotFather (see docs: Creating a Telegram Bot).
TELEGRAM_BOT_TOKEN="123456789:AA...replace-with-your-bot-token"

# Base URL of your Paperless-ngx instance (no trailing slash needed).
PAPERLESS_URL="https://paperless.example.com"

# Google AI Studio Gemini API key (see docs: Gemini API Key).
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# JSON object mapping Telegram user IDs to that user's Paperless API token.
# Each user only sees documents their token can access. Add one entry per user.
PAPERLESS_USER_TOKENS='{"52966251": "paperless-token-for-user-1", "12345678": "paperless-token-for-user-2"}'

# Optional: Gemini model to use. Defaults to the value below if unset.
GEMINI_MODEL="gemini-3.1-flash-lite"
